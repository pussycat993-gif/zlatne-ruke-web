# Kopiraj u .env.local i popuni svojim vrednostima.

# Clerk (auth) — https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Auth rute
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# Email kome se automatski dodeljuje admin uloga
ADMIN_EMAIL=

# Bazni URL sajta (canonical, OpenGraph, sitemap)
NEXT_PUBLIC_SITE_URL=https://zlatneruke.rs

# Cloudinary (upload slika) — Dashboard → Settings → API Keys
CLOUDINARY_CLOUD_NAME=djx2rkfte
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Supabase / Postgres (Drizzle) — Supabase Dashboard → Connect
# DATABASE_URL = Transaction pooler (port 6543) — koristi aplikacija u runtime-u.
DATABASE_URL=postgresql://postgres.<ref>:<lozinka>@aws-0-<region>.pooler.supabase.com:6543/postgres
# DIRECT_URL = Session pooler (port 5432) — koristi se za migracije i seed (DDL).
DIRECT_URL=postgresql://postgres.<ref>:<lozinka>@aws-0-<region>.pooler.supabase.com:5432/postgres
