# .env.test — SAMO za e2e testove. Kopiraj u `.env.test` i popuni.
# ⚠️ NIKAD ne stavljaj produkcioni DATABASE_URL ovde. Ovo mora biti ZASEBNA
#    Supabase TEST baza (drugi projekat/branch), da testovi ne diraju prave podatke.

# --- TEST baza (Supabase pooler, isti format kao .env.local, ali DRUGI projekat) ---
DATABASE_URL="postgresql://postgres.<TEST_REF>:<TEST_LOZINKA>@aws-1-eu-central-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.<TEST_REF>:<TEST_LOZINKA>@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# --- Clerk DEV instanca (isti test ključevi kao lokalno je ok; @clerk/testing) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Admin se određuje i preko ADMIN_EMAIL — postavi na e-mail test-admina.
ADMIN_EMAIL="admin+e2e@primer.com"

# --- Test korisnici (kreiraj ih u Clerk DEV instanci, email+password) ---
E2E_BUYER_EMAIL="buyer+e2e@primer.com"
E2E_BUYER_PASSWORD="..."

E2E_SELLER_A_EMAIL="sellerA+e2e@primer.com"
E2E_SELLER_A_PASSWORD="..."

E2E_SELLER_B_EMAIL="sellerB+e2e@primer.com"
E2E_SELLER_B_PASSWORD="..."

E2E_ADMIN_EMAIL="admin+e2e@primer.com"
E2E_ADMIN_PASSWORD="..."
